name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  analyze-and-test:
    runs-on: windows-latest
    steps:
      - uses: actions/checkout@v4
        with:
          lfs: true

      - uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.27'
          channel: 'stable'

      - name: Install dependencies (shared package)
        run: |
          cd packages/ssrvpn_shared
          flutter pub get

      - name: Install dependencies (app)
        run: flutter pub get

      - name: Analyze
        run: flutter analyze

      - name: Test (shared package)
        run: |
          cd packages/ssrvpn_shared
          flutter test

      - name: Test (app)
        run: flutter test

  build:
    if: startsWith(github.ref, 'refs/tags/')
    needs: analyze-and-test
    runs-on: windows-latest
    steps:
      - uses: actions/checkout@v4
        with:
          lfs: true

      - uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.27'
          channel: 'stable'

      - name: Build Windows
        run: |
          cd packages/ssrvpn_shared && flutter pub get
          cd ..
          flutter pub get
          flutter build windows --release

      - name: Package ZIP
        shell: powershell
        run: .\tool\package_windows.ps1

      - name: Upload ZIP
        uses: softprops/action-gh-release@v2
        with:
          files: SSRVPN.zip
